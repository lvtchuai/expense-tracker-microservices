{
  "name": "expense-tracker",
  "version": "0.1.0",
  "description": "Microservices expense tracker — Phase 1 (auth + transaction)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:auth": "nest build auth-service",
    "build:transaction": "nest build transaction-service",
    "build:notification": "nest build notification-service",
    "build:import": "nest build import-worker",
    "build:report": "nest build report-service",
    "build:group": "nest build group-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:auth": "nest start auth-service",
    "start:transaction": "nest start transaction-service",
    "start:notification": "nest start notification-service",
    "start:import": "nest start import-worker",
    "start:report": "nest start report-service",
    "start:group": "nest start group-service",
    "start:auth:dev": "nest start auth-service --watch",
    "start:transaction:dev": "nest start transaction-service --watch",
    "start:notification:dev": "nest start notification-service --watch",
    "start:import:dev": "nest start import-worker --watch",
    "start:report:dev": "nest start report-service --watch",
    "start:group:dev": "nest start group-service --watch",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "@types/passport-jwt": "^4.0.1",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}

# Copy to .env for local docker-compose. DO NOT commit real secrets.

# Shared across services — must be identical so tokens verify everywhere.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1h

# Service-to-service auth (import-worker -> transaction-service). Keep secret.
INTERNAL_API_KEY=dev-internal-key-change-me

# Postgres credentials (same user/pass for both DBs in local dev)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ credentials
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Host ports (change if taken; 5434/5433 avoid a local Postgres on 5432)
WEB_PORT=3000
AUTH_PORT=3001
TRANSACTION_PORT=3002
NOTIFICATION_PORT=3003
IMPORT_WORKER_PORT=3004
REPORT_PORT=3005
AUTH_DB_PORT=5434
TRANSACTION_DB_PORT=5433
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

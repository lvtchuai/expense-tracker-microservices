# Copy to .env for local docker-compose. DO NOT commit real secrets.

# Shared across services — must be identical so tokens verify everywhere.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1h

# Postgres credentials (same user/pass for both DBs in local dev)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host ports (change if taken; 5434/5433 avoid a local Postgres on 5432)
AUTH_PORT=3001
TRANSACTION_PORT=3002
AUTH_DB_PORT=5434
TRANSACTION_DB_PORT=5433
